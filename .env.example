# ========================================
# 固定资产管理系统 - 环境变量配置
# ========================================
# 复制此文件为 .env 并根据实际环境修改
# cp .env.example .env

# ===== 数据库配置 =====
# MySQL 主机地址
MYSQL_HOST=localhost

# MySQL 端口
MYSQL_PORT=3306

# 数据库名
MYSQL_DATABASE=fixed_asset_lifecycle_system

# MySQL 用户名
MYSQL_USERNAME=root

# MySQL 密码
MYSQL_PASSWORD=123456

# ===== 后端配置 =====
# 后端服务端口
BACKEND_PORT=8080

# JWT 密钥
JWT_SECRET=fixed-asset-lifecycle-system-jwt-secret-key-2026-asset-platform

# JWT 过期时间（分钟）
JWT_EXPIRATION_MINUTES=720

# ===== 前端配置 =====
# 前端开发服务器端口
FRONTEND_PORT=3000

# 后端 API 地址（开发环境通过 Vite proxy 转发）
VITE_API_BASE_URL=/api
